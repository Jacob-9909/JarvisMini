# Global Database Configuration
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=bookchecker_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Global Notifications (For the System Bot)
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_APP_TOKEN=your_slack_app_token

# LLM Configuration
MODEL=gemini-2.5-flash

# System Config
AGENT_INTERVAL_SECONDS=300
MAX_RETRIES=3

# --- NOTE FOR MULTI-TENANCY ---
# TARGET_URL, ANNIVERSARY_DATE, BUFFER_DAYS, TARGET_USER_ID, TARGET_USER_PASSWORD, and SLACK_CHANNEL_ID 
# have been moved to the PostgreSQL Database (`users` and `user_configs` tables).
# Run `uv run python -m src.scheduler --seed` to inject a test user into the database.
