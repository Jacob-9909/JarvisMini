# ==== Database ====
# 주의: Docker 볼륨이 이미 생성된 뒤에는 여기만 바꿔도 DB 사용자/비번이 바뀌지 않습니다.
#       password authentication failed → (1) 예전에 쓰던 USER/PASS로 맞추거나
#       (2) 볼륨 삭제 후 재기동: docker compose -f docker/docker-compose.yaml down -v && ... up -d
POSTGRES_USER=officeuser
POSTGRES_PASSWORD=officepass
POSTGRES_DB=smart_office_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ==== LLM / ADK ====
MODEL=gemini-2.5-flash
# 펫 챗봇(/api/chat)이 사용. Google AI Studio(https://aistudio.google.com/apikey) 에서 발급.
# Vertex 사용 시엔 GOOGLE_GENAI_USE_VERTEXAI=TRUE + GOOGLE_CLOUD_PROJECT/GOOGLE_CLOUD_LOCATION
GOOGLE_API_KEY=
# GOOGLE_GENAI_USE_VERTEXAI=FALSE
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# ==== Scheduler ====
AGENT_INTERVAL_SECONDS=60        # System Monitor 샘플링 주기 (scheduler 전용)
BUS_INTERVAL_SECONDS=60          # 버스 알림 체크 주기
BUS_NOTIFY_THRESHOLD_MIN=5       # 이 분 이하로 임박 시 알림
IDLE_DECAY_INTERVAL_SECONDS=600  # 스트레스 자연 감소 주기

# ==== Web 위젯 백그라운드 모니터 ====
# 전역 클릭/키보드 + CPU/RAM 샘플 → EXP 반영 주기(초). 스케줄러와 동시에 켜면 EXP가 이중 적용될 수 있음.
WEB_MONITOR_INTERVAL_SECONDS=30
WEB_BACKGROUND_MONITOR=true

# ==== 외부 API ====
# 카카오 REST 키 (지도/로컬용 — 버스 조회엔 불필요)
KAKAO_REST_KEY=

# ---- 버스 API (서울시 공공데이터포털) ----
# 공공데이터포털(https://www.data.go.kr)에서 아래 서비스를 활용신청하여 키를 발급받습니다.
#   - "서울특별시_정류소정보조회 서비스"  (getStationByUidItem, getStationByName)
#   - "서울특별시_버스도착정보조회 서비스" (선택, 노선 단위 조회용)
# 마이페이지 → 내 API → 해당 서비스 → "인증키(Decoding)" 또는 "인증키(Encoding)" 중 하나 복사.
# (권장: Decoding. Encoding 을 넣어도 코드에서 한 번 풀어서 사용함)
SEOUL_BUS_API_KEY=
SEOUL_BUS_BASE_URL=http://ws.bus.go.kr/api/rest/stationinfo
# BUS_USE_MOCK=1 로 두면 실제 호출 없이 mock 응답을 사용합니다 (개발/오프라인용)
BUS_USE_MOCK=0

# 네이버 맵 (옵션)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---- Google Maps JS API (카페 탭 지도 시각화용, 옵션) ----
# https://console.cloud.google.com > Google Maps JavaScript API 활성화 → API 키 발급
# (Map ID 는 선택. AdvancedMarker/다크 스타일을 콘솔에서 커스텀하려면 지정 권장)
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_MAP_ID=

# 구글 캘린더 OAuth 토큰 경로 (optional)
GOOGLE_CALENDAR_TOKEN_PATH=

# ==== 알림 (Optional) ====
SLACK_BOT_TOKEN=

# ==== 멀티테넌시 안내 ====
# 사용자의 좌표/직군/펫 정보는 PostgreSQL 의 auth.users, agent_state.pet_profile 에 저장됩니다.
# 테스트 사용자 주입: uv run python -m src.main --mode seed
